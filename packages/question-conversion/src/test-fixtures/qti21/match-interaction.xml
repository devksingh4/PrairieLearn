<?xml version="1.0" encoding="UTF-8"?>
<assessmentItem xmlns="http://www.imsglobal.org/xsd/imsqti_v2p1"
  identifier="q-match" title="Matching Question" adaptive="false" timeDependent="false">
  <responseDeclaration identifier="RESPONSE" cardinality="multiple" baseType="directedPair">
    <correctResponse>
      <value>A P</value>
      <value>B Q</value>
    </correctResponse>
  </responseDeclaration>
  <itemBody>
    <p>Match each country to its capital.</p>
    <matchInteraction responseIdentifier="RESPONSE" shuffle="false" maxAssociations="2">
      <simpleMatchSet>
        <simpleAssociableChoice identifier="A" matchMax="1">France</simpleAssociableChoice>
        <simpleAssociableChoice identifier="B" matchMax="1">Germany</simpleAssociableChoice>
      </simpleMatchSet>
      <simpleMatchSet>
        <simpleAssociableChoice identifier="P" matchMax="1">Paris</simpleAssociableChoice>
        <simpleAssociableChoice identifier="Q" matchMax="1">Berlin</simpleAssociableChoice>
        <simpleAssociableChoice identifier="R" matchMax="1">Madrid</simpleAssociableChoice>
      </simpleMatchSet>
    </matchInteraction>
  </itemBody>
</assessmentItem>
